# ============================================================
# .env.example — copy to .env and fill in your values
# NEVER commit your real .env file to git
# ============================================================

# ---- LiveKit ------------------------------------------------
# Get these from https://cloud.livekit.io → Project → Settings
LIVEKIT_URL=wss://your-project.livekit.cloud
LIVEKIT_API_KEY=your_livekit_api_key
LIVEKIT_API_SECRET=your_livekit_api_secret

# ---- Gemini / Google ----------------------------------------
# https://aistudio.google.com/app/apikey
GOOGLE_API_KEY=your_google_api_key

# ---- Groq ---------------------------------------------------
# https://console.groq.com/keys
GROQ_API_KEY=your_groq_api_key

# ---- Sarvam AI (STT / TTS) ----------------------------------
# https://dashboard.sarvam.ai
SARVAM_API_KEY=your_sarvam_api_key

# ---- ElevenLabs TTS (optional fallback) ---------------------
# https://elevenlabs.io/app/settings/api-keys
ELEVENLABS_API_KEY=your_elevenlabs_api_key
ELEVEN_API_KEY=your_elevenlabs_api_key   # alias used by some plugins

# ---- Deepgram STT (optional fallback) -----------------------
# https://console.deepgram.com
DEEPGRAM_API_KEY=your_deepgram_api_key

# ---- OpenAI (optional fallback) -----------------------------
# https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_api_key

# ---- Azure OpenAI (optional) --------------------------------
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/
AZURE_OPENAI_KEY=your_azure_openai_key

# ---- Email (Gmail SMTP) -------------------------------------
# Use a Gmail App Password, NOT your account password
# https://myaccount.google.com/apppasswords
Email__SenderEmail=you@gmail.com
Email__SenderPassword=xxxx xxxx xxxx xxxx
Email__SenderName=Voice Agent
Email__SmtpHost=smtp.gmail.com
Email__SmtpPort=587

# ---- Voice Agent Behaviour ----------------------------------
TTS_PROVIDER=sarvam           # sarvam | elevenlabs | openai | azure
TTS_VOICE=anushka
TTS_MODEL=bulbul:v1
TTS_FALLBACK_ENABLED=false
PLAYGROUND_MODE=True          # True = accept any room; False = explicit dispatch only
AGENT_NAME=Hindi-English-Voice-Agent
AGENT_PORT=8081
LOG_LEVEL=INFO

# ---- .NET API -----------------------------------------------
ASPNETCORE_ENVIRONMENT=Development
