# ============================================
# ENVIRONMENT VARIABLES TEMPLATE
# ============================================
# Copy this file to .env and fill in your API keys
# Usage: cp .env.example .env
# Then edit .env with your actual credentials
# ============================================

# ============================================
# LIVEKIT CONFIGURATION (Required)
# ============================================
# Get these from: https://cloud.livekit.io
LIVEKIT_URL=wss://your-project.livekit.cloud
LIVEKIT_API_KEY=your_api_key_here
LIVEKIT_API_SECRET=your_api_secret_here

# ============================================
# SPEECH-TO-TEXT (STT) PROVIDERS
# ============================================

***REMOVED*** (Recommended for English)
# Get key from: https://console.deepgram.com
DEEPGRAM_API_KEY=your_deepgram_key_here

***REMOVED*** (Recommended for Hindi/Indian languages)
# Get key from: https://www.sarvam.ai
SARVAM_API_KEY=your_sarvam_key_here

# ============================================
# LARGE LANGUAGE MODEL (LLM) PROVIDERS
# ============================================

# Groq (Fast, Free tier available)
# Get key from: https://console.groq.com
GROQ_API_KEY=your_groq_key_here

***REMOVED*** (Optional - if using Azure)
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/
AZURE_OPENAI_API_KEY=your_azure_openai_key_here

# ============================================
# APPLICATION SETTINGS
# ============================================

# Environment mode (Development, Staging, Production)
ASPNETCORE_ENVIRONMENT=Development

# Agent worker port
AGENT_PORT=8081

# Logging level (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO

# Playground mode (set to true for LiveKit playground testing)
PLAYGROUND_MODE=false

# ============================================
# OPTIONAL: DATABASE (Future use)
# ============================================
# DATABASE_URL=postgresql://user:password@localhost:5432/voiceagent
# REDIS_URL=redis://localhost:6379

# ============================================
# OPTIONAL: EMAIL SERVICE (For transcripts)
# ============================================
# SENDGRID_API_KEY=your_sendgrid_key
# AWS_SES_ACCESS_KEY=your_aws_key
# AWS_SES_SECRET_KEY=your_aws_secret

# ============================================
# NOTES
# ============================================
# 1. NEVER commit .env to git (it's in .gitignore)
# 2. Keep this .env.example updated with new variables
# 3. Each developer should have their own .env file
# 4. For production, use environment variables or secrets manager
