# ============================================
# DOCKERIGNORE FOR PYTHON AGENT
# ============================================

# Virtual environments
.venv/
venv/
env/
ENV/

# Python cache
__pycache__/
*.py[cod]
*$py.class
*.so

# Distribution / packaging
build/
dist/
*.egg-info/
.eggs/

# Environment files — NEVER bake secrets into the image
.env
.env.local
*.env
.secrets
.secrets.backup
*.secrets

# Logs
*.log
logs/
agent.log

# Test files
.pytest_cache/
.coverage
htmlcov/
.tox/

# IDE
.vscode/
.idea/
*.swp
*.swo

# Git
.git/
.gitignore

# Documentation
README.md
*.md

# macOS
.DS_Store

# Windows
Thumbs.db

# UV lock file (will be regenerated)
uv.lock

# Python version file
.python-version
